# IAB Deals MCP Server Configuration

# Environment: demo, development, production
NODE_ENV=demo

# API Key for MCP server authentication
IAB_DEALS_API_KEY=demo-api-key-change-in-production

# Database (SQLite path or Turso URL)
DATABASE_URL=file:./data/deals.db

# Logging
LOG_LEVEL=info

# Demo mode - seed sample data on startup
SEED_DEMO_DATA=true

# Provider credentials (for production integrations)
# The Trade Desk
# TTD_API_KEY=
# TTD_PARTNER_ID=

# Google DV360
# DV360_SERVICE_ACCOUNT_JSON=

# FreeWheel
# FREEWHEEL_CLIENT_ID=
# FREEWHEEL_CLIENT_SECRET=

# Magnite
# MAGNITE_API_KEY=
